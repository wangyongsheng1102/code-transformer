<RuleSet>
  <name>Portal2Step2InfrastructureRules</name>
  <type>PROJECT</type>

  <PackageRules/>
  <ImportRules>
    <ImportRule>
      <enabled>true</enabled>
      <priority>10</priority>
      <Match>org.springframework.web.bind.annotation.RequestMapping</Match>
      <Action>ADD</Action>
    </ImportRule>
    <ImportRule>
      <enabled>true</enabled>
      <priority>11</priority>
      <Match>org.springframework.ui.ModelMap</Match>
      <Action>ADD</Action>
    </ImportRule>
    <ImportRule>
      <enabled>true</enabled>
      <priority>12</priority>
      <Match>jakarta.servlet.http.HttpServletRequest</Match>
      <Action>ADD</Action>
    </ImportRule>
    <ImportRule>
      <enabled>true</enabled>
      <priority>13</priority>
      <Match>jakarta.servlet.http.HttpSession</Match>
      <Action>ADD</Action>
    </ImportRule>
    <ImportRule>
      <enabled>true</enabled>
      <priority>14</priority>
      <Match>org.springframework.beans.factory.annotation.Autowired</Match>
      <Action>ADD</Action>
    </ImportRule>
    <ImportRule>
      <enabled>true</enabled>
      <priority>15</priority>
      <Match>org.springframework.stereotype.Controller</Match>
      <Action>ADD</Action>
    </ImportRule>
  </ImportRules>

  <ClassRules>
    <ClassRule>
      <enabled>true</enabled>
      <priority>100</priority>
      <ExtendsClass>AbstractAction</ExtendsClass>
      <ReplaceExtends>BaseController</ReplaceExtends>
      <AddAnnotations>
        <Annotation>org.springframework.stereotype.Controller</Annotation>
      </AddAnnotations>
      <AddFields>
        <Field>
          <Type>jakarta.servlet.http.HttpSession</Type>
          <Name>sessionMap</Name>
          <Modifier>protected</Modifier>
          <Annotations>
            <Annotation>org.springframework.beans.factory.annotation.Autowired</Annotation>
          </Annotations>
        </Field>
        <Field>
          <Type>jakarta.servlet.http.HttpServletRequest</Type>
          <Name>httpRequest</Name>
          <Modifier>protected</Modifier>
          <Annotations>
            <Annotation>org.springframework.beans.factory.annotation.Autowired</Annotation>
          </Annotations>
        </Field>
      </AddFields>
    </ClassRule>
  </ClassRules>

  <MethodRules>
    <MethodRule>
      <enabled>true</enabled>
      <priority>180</priority>
      <Action>MODIFY</Action>
      <BodyTextReplacements>
        <Rule>
          <From>sessionMap.clear();</From>
          <To>if (sessionMap != null) { sessionMap.invalidate(); }</To>
        </Rule>
      </BodyTextReplacements>
    </MethodRule>

    <MethodRule>
      <enabled>true</enabled>
      <priority>200</priority>
      <Name>execute</Name>
      <Action>MODIFY</Action>
      <AddAnnotations>
        <Annotation>org.springframework.web.bind.annotation.RequestMapping</Annotation>
      </AddAnnotations>
      <AddParameters>
        <Parameter>org.springframework.ui.ModelMap modelMap</Parameter>
      </AddParameters>
    </MethodRule>
    <MethodRule>
      <enabled>true</enabled>
      <priority>201</priority>
      <Name>next</Name>
      <Action>MODIFY</Action>
      <AddAnnotations>
        <Annotation>org.springframework.web.bind.annotation.RequestMapping</Annotation>
      </AddAnnotations>
      <AddParameters>
        <Parameter>org.springframework.ui.ModelMap modelMap</Parameter>
      </AddParameters>
    </MethodRule>
    <MethodRule>
      <enabled>true</enabled>
      <priority>202</priority>
      <Name>back</Name>
      <Action>MODIFY</Action>
      <AddAnnotations>
        <Annotation>org.springframework.web.bind.annotation.RequestMapping</Annotation>
      </AddAnnotations>
      <AddParameters>
        <Parameter>org.springframework.ui.ModelMap modelMap</Parameter>
      </AddParameters>
    </MethodRule>
    <MethodRule>
      <enabled>true</enabled>
      <priority>203</priority>
      <Name>login</Name>
      <Action>MODIFY</Action>
      <AddAnnotations>
        <Annotation>org.springframework.web.bind.annotation.RequestMapping</Annotation>
      </AddAnnotations>
      <AddParameters>
        <Parameter>org.springframework.ui.ModelMap modelMap</Parameter>
      </AddParameters>
    </MethodRule>
  </MethodRules>
</RuleSet>
